  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "@types/node": "^25.4.0",
    "tsdown": "^0.21.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "ansis": "^4.2.0",
    "c12": "^4.0.0-beta.3",
    "ccxt": "^4.5.42",
    "citty": "^0.2.1",
    "console-table-printer": "^2.15.0",
    "viem": "^2.47.1",
    "zod": "^4.3.6"
  }
