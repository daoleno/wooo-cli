{
  "name": "wooo-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "wooo": "./dist/index.mjs"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown src/index.ts --format esm --dts",
