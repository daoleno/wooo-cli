{
  "name": "wooo-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "wooo": "./dist/index.mjs"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown src/index.ts --format esm --dts",
    "type-check": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "test": "bun test",
    "test:e2e:anvil": "bun test ./tests/e2e/anvil-fork.e2e.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "@types/node": "^25.4.0",
    "tsdown": "^0.21.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@curvefi/api": "^2.68.38",
    "@lidofinance/lido-ethereum-sdk": "^4.7.0",
    "@solana/web3.js": "1",
    "@uniswap/sdk-core": "^7.12.1",
    "@uniswap/smart-order-router": "^4.31.10",
    "@uniswap/v3-sdk": "^3.29.1",
    "ansis": "^4.2.0",
    "bs58": "^6.0.0",
    "c12": "^4.0.0-beta.3",
    "ccxt": "^4.5.42",
    "citty": "^0.2.1",
    "console-table-printer": "^2.15.0",
    "ethers": "^6.16.0",
    "viem": "^2.47.1",
    "zod": "^4.3.6"
  }
}
