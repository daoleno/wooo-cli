{
  "name": "wooo-cli",
  "version": "0.1.2",
  "description": "Terminal-native copilot for trading, DeFi, and on-chain execution.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daoleno/wooo-cli.git"
  },
  "homepage": "https://github.com/daoleno/wooo-cli#readme",
  "bugs": {
    "url": "https://github.com/daoleno/wooo-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "wooo-cli": "./bin/wooo-cli.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown src/index.ts --format esm --dts",
    "type-check": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "test": "bun test",
    "test:e2e": "bun test --max-concurrency=1 ./tests/e2e/*.e2e.ts",
    "test:e2e:anvil": "bun test --max-concurrency=1 ./tests/e2e/*anvil*.e2e.ts",
    "test:e2e:local": "bun test ./tests/e2e/*local*.e2e.ts",
    "ci:check": "bun run build && bun run lint:fix && bun run lint && bun run type-check && bun test",
    "release:verify:full": "bun run ci:check && bun run test:e2e && npm run package:check",
    "package:check": "npm pack --dry-run",
    "release:verify": "bun run ci:check && npm run package:check",
    "prepublishOnly": "bun run release:verify"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "@types/node": "^25.4.0",
    "tsdown": "^0.21.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@curvefi/api": "^2.68.38",
    "@lidofinance/lido-ethereum-sdk": "^4.7.0",
    "@lifi/sdk": "^3.16.3",
    "@morpho-org/blue-sdk": "^5.18.0",
    "@morpho-org/blue-sdk-viem": "^4.5.0",
    "@open-wallet-standard/core": "^1.0.0",
    "@polymarket/clob-client": "^5.8.0",
    "@solana/web3.js": "1",
    "@uniswap/sdk-core": "^7.12.1",
    "@uniswap/smart-order-router": "^4.31.10",
    "@uniswap/v3-sdk": "^3.29.1",
    "ansis": "^4.2.0",
    "bs58": "^6.0.0",
    "c12": "^4.0.0-beta.3",
    "ccxt": "^4.5.42",
    "citty": "^0.2.1",
    "console-table-printer": "^2.15.0",
    "ethers": "^6.16.0",
    "mppx": "^0.4.7",
    "viem": "^2.47.1",
    "x402": "^1.1.0",
    "zod": "^4.3.6"
  }
}
